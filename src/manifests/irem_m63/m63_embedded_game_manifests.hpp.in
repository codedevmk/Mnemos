                                @MNEMOS_IREM_M63_GAME_MANIFEST_COUNT@>
        game_manifests{{
@MNEMOS_IREM_M63_EMBEDDED_ENTRIES@
        }};

} // namespace mnemos::manifests::irem_m63::embedded
