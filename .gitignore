# Build outputs
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json

# Binaries, ROMs, and firmware dumps
*.bin
.bin/
roms/
firmware/

# Scratch / debug artifacts. Canonical home is scratch/ -- headless --screenshot
# framebuffers, VRAM/CRAM dumps, trace CSVs, ad-hoc logs, and coverage profraw
# all belong there (see AGENTS.md "Scratch artifacts"). Cleared by
# scripts/clean-scratch.ps1. Never committed.
/scratch/
# Legacy / session-specific scratch dirs: kept locally for in-flight debugging
# (e.g. Genesis A/B traces) but never committed.
scratch_sms/
diverge_scratch/
# Catch-all for stray framebuffer dumps written outside scratch/.
*.ppm

# Temporary files
tmp/
*.tmp
*.temp

# Log files
log/
logs/
*.log

# Package manager artifacts
vcpkg_installed/
.conan/
conanbuildinfo.*
conan.lock

# IDE and editor state
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Tech sheets
.techsheets/

# Coverage profiling artifacts
*.profraw
*.profdata

# Local developer tooling lives in scripts/ and is not part of the committed
# source -- machine-specific paths, ad-hoc diagnostic harnesses, build helpers.
scripts/

# Working/scratch documents that are not part of the public history
docs/genesis-cycle-parity-audit.md
docs/genesis-chipset-gap-audit.md
*.obj

# Session-local agent tooling (Ralph loop)
.claude/
