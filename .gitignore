# Build outputs
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json
_scratch/

# Binaries, ROMs, and firmware dumps
*.bin
.bin/
roms/
firmware/

# Transient build/debug artifacts: canonical home is build/ (ADR-0025 rule 1) --
# build/scratch/ holds headless --screenshot framebuffers, VRAM/CRAM dumps, trace
# CSVs, ad-hoc logs, and coverage profraw. build/ is ignored above.
# Catch-all for stray framebuffer dumps written outside scratch/.
*.ppm

# Temporary files
tmp/
*.tmp
*.temp

# Log files
log/
logs/
*.log

# Package manager artifacts
vcpkg_installed/
.conan/
conanbuildinfo.*
conan.lock

# IDE and editor state
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Tech sheets
.techsheets/

# Coverage profiling artifacts
*.profraw
*.profdata

# Scripts are tracked + organized under scripts/{sub}/ (ADR-0025 rule 5). Only
# machine-specific / local-only scripts stay out of history, by naming convention:
scripts/local-*
scripts/**/local-*
scripts/**/*.local.*
/scripts/local/
# GPGX differential runners: local-only reference tooling. They name a third-party
# oracle, so they stay out of committed history (THIRD-PARTY-REFERENCES.md / no-3rd-party-names
# rule). Version a name-scrubbed copy under tools/ only if explicitly wanted.
scripts/gpgx_*.c

# Working/scratch documents that are not part of the public history
docs/audit/
*.obj

# Session-local agent tooling (Ralph loop) — but the decision-capture
# command and the session-instrumentation hooks are repository tooling
# (MNE-CTX-PLAN-001 §5.2/§8) and stay tracked.
.claude/*
!.claude/commands/
!.claude/settings.json
__pycache__/

# Arbor runtime state: conversations, sessions, checkpoints, reports, and
# coordinator scratch data are local-only and must not dirty research repos.
.arbor/
.autoresearch/
.coordinator/

# Raw session telemetry (M7/M15 inputs) — aggregated into committed
# snapshots by metrics.py; the raw logs are working data, never authority.
metrics/sessions/
results/
cache_old_*/
