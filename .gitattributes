* text=auto

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf

# Git hooks are extensionless shell scripts — force LF so the shebang works on Linux.
tools/githooks/* text eol=lf

*.bin binary
*.bmp binary
*.d64 binary
*.gif binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.png binary
*.rom binary
*.wav binary
*.zip binary
*.7z binary
*.rar binary
*.iso binary
*.bz2 binary
